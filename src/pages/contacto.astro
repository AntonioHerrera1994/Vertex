---

import HeaderPages from '../components/HeaderPages.astro'
import Formulario from '../components/Formulario.astro'
import Footer from '../components/Footer.astro'
import MotivationalBanner from '../components/MotivationalBanner.astro';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/logo.png" />
		<meta name="generator" content={Astro.generator} />
		 <link rel="sitemap" href="/sitemap-index.xml" />
			<title>Contacto | Vertex Freight Services</title>
<meta name="description" content="Estamos listos para ayudarle. ¿Necesita cotizar un envío o tiene preguntas sobre nuestros servicios? Contáctenos hoy mismo y encuentre la solución perfecta.">
<meta name="keywords" content="logística internacional, transporte de carga, agente aduanal México, freight forwarding, importación exportación">
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
<meta name="googlebot" content="index, follow">
		<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
	</head>
	<body>
		<HeaderPages title='Contacto'/>
<Formulario />
	<MotivationalBanner />

	<Footer />

	</body>
</html>


	
<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
