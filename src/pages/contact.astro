---
import HeaderPagen from "../components/ingles/HeaderPagen.astro"
import Formularioen from "../components/ingles/Formularioen.astro"
import MotivBanen from "../components/ingles/MotivBanen.astro"
import Footeren from "../components/ingles/Footeren.astro"
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/logo.png" />
		<meta name="generator" content={Astro.generator} />
			  <link rel="sitemap" href="/sitemap-index.xml" />
			<title>Contact | Vertex Freight Services</title>
<meta name="description" content="We are ready to help you. Do you need a shipping quote or have questions about our services? Contact us today and find the perfect solution.">
<meta name="keywords" content="international logistics, freight transport, customs agent Mexico, freight forwarding, import export">
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
<meta name="googlebot" content="index, follow">
		<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
	</head>

    <HeaderPagen title="Contact" />
    <Formularioen />
	<MotivBanen />
	<Footeren />
</html>


	
<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
